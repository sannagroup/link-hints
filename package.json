{
  "name": "@sannagroup/link-hints",
  "version": "0.6.0",
  "description": "Vimium-style keyboard link-hint navigation for any web page. Pure JS / TypeScript, framework-free.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/style/style.css dist/style.css",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "vimium",
    "keyboard",
    "hint",
    "accessibility",
    "navigation",
    "shortcuts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sannagroup/link-hints.git"
  },
  "homepage": "https://github.com/sannagroup/link-hints#readme",
  "bugs": "https://github.com/sannagroup/link-hints/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@storybook/html-vite": "^10.3.6",
    "@types/jsdom": "^21.1.7",
    "@vitest/coverage-v8": "2.1.9",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "storybook": "^10.3.6",
    "typescript": "^5.7.2",
    "vite": "^8.0.10",
    "vitest": "^2.1.8"
  },
  "packageManager": "bun@1.3.13"
}
