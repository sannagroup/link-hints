{
  "name": "hint-mode-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Vimium-style keyboard hint navigation for the web. Pure JS core + framework adapters.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter='./packages/*' build",
    "test": "bun run --filter='./packages/*' test",
    "typecheck": "bun run --filter='./packages/*' typecheck",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.13"
}
